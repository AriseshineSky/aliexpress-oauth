<% content_for :title, "Product #{@product_id}" %>

<section class="space-y-6">
  <div>
    <h1 class="text-2xl font-semibold">Product <%= @product_id %></h1>
    <p class="mt-1 text-sm text-slate-500"><%= @local_country %> · <%= @local_language %></p>
  </div>

  <% if @error %>
    <p class="rounded-md bg-red-50 px-4 py-3 text-sm text-red-800"><%= @error %></p>
  <% elsif @skus %>
    <div class="overflow-x-auto rounded-lg border border-slate-200 bg-white">
      <table class="min-w-full text-left text-sm">
        <thead class="border-b bg-slate-50 text-slate-500">
          <tr>
            <th class="px-4 py-3 font-medium">SKU</th>
            <th class="px-4 py-3 font-medium">划线价 sku_price</th>
            <th class="px-4 py-3 font-medium">售价 offer_sale_price</th>
            <th class="px-4 py-3 font-medium">库存</th>
          </tr>
        </thead>
        <tbody>
          <% @skus.each do |sku| %>
            <tr class="border-b border-slate-100">
              <td class="px-4 py-3 font-mono text-xs"><%= sku[:sku_id] %></td>
              <td class="px-4 py-3"><%= sku[:sku_price] %></td>
              <td class="px-4 py-3 font-medium text-orange-700"><%= sku[:offer_sale_price] %></td>
              <td class="px-4 py-3"><%= sku[:sku_stock] %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>

    <details class="rounded-lg border border-slate-200 bg-white p-4">
      <summary class="cursor-pointer text-sm text-slate-600">Raw JSON</summary>
      <pre class="mt-3 overflow-x-auto text-xs"><%= JSON.pretty_generate(@raw) %></pre>
    </details>
  <% end %>

  <%= link_to "返回首页", root_path, class: "text-sm text-orange-700 hover:underline" %>
</section>
