<% content_for :title, "授权成功" %>

<section class="space-y-6">
  <div>
    <h1 class="text-2xl font-semibold text-emerald-700">授权成功</h1>
    <p class="mt-2 text-slate-600">已用 callback 中的 code 换取 access_token，并写入 Redis（页面仅显示打码 Token）。</p>
  </div>

  <% if @token %>
    <dl class="space-y-3 rounded-lg border border-slate-200 bg-white p-5 text-sm">
      <div>
        <dt class="text-slate-500">App Key</dt>
        <dd class="font-mono text-slate-900"><%= @app_key.presence || @token.try(:app_key).presence || "—" %></dd>
      </div>
      <div>
        <dt class="text-slate-500">Account</dt>
        <dd class="font-mono text-slate-900"><%= @token.account.presence || "—" %></dd>
      </div>
      <div>
        <dt class="text-slate-500">User ID</dt>
        <dd class="font-mono text-slate-900"><%= @token.user_id.presence || "—" %></dd>
      </div>
      <div>
        <dt class="text-slate-500">Access Token</dt>
        <dd class="font-mono text-xs text-slate-800"><%= mask_secret(@token.access_token) %></dd>
      </div>
      <div>
        <dt class="text-slate-500">Refresh Token</dt>
        <dd class="font-mono text-xs text-slate-800"><%= mask_secret(@token.refresh_token) %></dd>
      </div>
      <div>
        <dt class="text-slate-500">Expires At</dt>
        <dd><%= @token.expires_at || "—" %></dd>
      </div>
    </dl>
  <% end %>

  <%= link_to "返回控制台", root_path, class: "text-sm text-orange-700 hover:underline" %>
</section>
