# Copy to .env and fill in credentials from AliExpress App Console
ALIEXPRESS_APP_KEY=your_app_key
ALIEXPRESS_APP_SECRET=your_app_secret

# Must match the Callback URL registered in App Console exactly
# Local:     http://localhost:3000/callback
# Render:    https://everymarket.onrender.com/callback
ALIEXPRESS_CALLBACK_URL=http://localhost:3000/callback

# Upstash Redis (production strongly recommended — free 10k cmd/day)
# REDIS_URL=rediss://default:PASSWORD@REGION.upstash.io:6379

# IOP REST gateway (Singapore is the usual production host for Dropshipping)
ALIEXPRESS_API_BASE=https://api-sg.aliexpress.com/rest

# OAuth authorize page
ALIEXPRESS_AUTHORIZE_URL=https://api-sg.aliexpress.com/oauth/authorize

# Token create endpoint path (relative to API_BASE)
# Use /auth/token/security/create if your app requires the security variant
ALIEXPRESS_TOKEN_PATH=/auth/token/create

# Set automatically by bin/tunnel (Cloudflare quick tunnel HTTPS origin)
# ALIEXPRESS_PUBLIC_HOST=https://xxxx.trycloudflare.com
