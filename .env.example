# === 本地开发 ===
# Preferred: open the console and POST App Key/Secret into Redis (no env needed).
# Optional bootstrap via env (merged with Redis; env wins on same app_key):
# ALIEXPRESS_APP_KEY=your_app_key
# ALIEXPRESS_APP_SECRET=your_app_secret
# ALIEXPRESS_APP_LABEL=primary

# Legacy multi-app env (prefer Redis console instead):
# ALIEXPRESS_APP_KEY_2=539578
# ALIEXPRESS_APP_SECRET_2=your_second_secret
# ALIEXPRESS_APP_LABEL_2=vps2
# ALIEXPRESS_APPS_JSON=[{"app_key":"539578","app_secret":"...","label":"vps2"}]

ALIEXPRESS_CALLBACK_URL=http://localhost:3000/callback

# Upstash（本地可选；生产 Render 必填）
# REDIS_URL=rediss://default:PASSWORD@xxxxx.upstash.io:6379

ALIEXPRESS_API_BASE=https://api-sg.aliexpress.com/rest
ALIEXPRESS_AUTHORIZE_URL=https://api-sg.aliexpress.com/oauth/authorize
ALIEXPRESS_TOKEN_PATH=/auth/token/create

# === Render 生产（在 Dashboard Environment 里填，不要写进仓库）===
# RAILS_ENV=production
# APP_HOST=aliexpress-oauth.onrender.com
# ALIEXPRESS_CALLBACK_URL=https://aliexpress-oauth.onrender.com/callback
# ALIEXPRESS_API_BASE=https://api-sg.aliexpress.com/rest
# ALIEXPRESS_AUTHORIZE_URL=https://api-sg.aliexpress.com/oauth/authorize
# ALIEXPRESS_TOKEN_PATH=/auth/token/create
# ALIEXPRESS_APP_KEY=...
# ALIEXPRESS_APP_SECRET=...
# ALIEXPRESS_APP_KEY_2=...
# ALIEXPRESS_APP_SECRET_2=...
# REDIS_URL=rediss://default:...@....upstash.io:6379
# SECRET_KEY_BASE=（Render Generate）
# BASIC_AUTH_USER=admin
# BASIC_AUTH_PASSWORD=强密码

# HTTP Basic Auth for console (REQUIRED on public Render). Empty = disabled.
BASIC_AUTH_USER=admin
BASIC_AUTH_PASSWORD=change-me-strong-password
