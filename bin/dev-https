#!/usr/bin/env bash
# Start Rails (bin/dev) + Cloudflare HTTPS tunnel together.
# Uses two processes; tunnel URL is synced into .env automatically.
set -euo pipefail

ROOT="$(cd "$(dirname "$0")/.." && pwd)"
cd "$ROOT"

PORT="${PORT:-3000}"
export PORT

mkdir -p tmp

# Ensure DB is ready
bin/rails db:prepare >/dev/null

# Start Rails stack first so tunnel has something to hit
bin/dev &
DEV_PID=$!

cleanup() {
  echo
  echo "Stopping Rails (pid $DEV_PID)..."
  kill "$DEV_PID" 2>/dev/null || true
  # foreman/bin/dev may leave children; best-effort
  pkill -P "$DEV_PID" 2>/dev/null || true
}
trap cleanup EXIT INT TERM

# Wait for local port
for _ in $(seq 1 60); do
  if curl -sf "http://127.0.0.1:${PORT}/up" >/dev/null 2>&1; then
    break
  fi
  sleep 0.5
done

echo "Local Rails is up on :${PORT}"
echo "Starting HTTPS tunnel..."
echo

# bin/tunnel blocks until Ctrl+C; after it updates .env ask user to restart
# if they already had wrong callback. For first boot, restart rails once URL is known.
bin/tunnel &
TUNNEL_PID=$!

# Wait until tunnel URL file exists, then bounce Rails so Oauth picks new CALLBACK_URL
for _ in $(seq 1 90); do
  if [[ -f tmp/tunnel_url.txt ]]; then
    break
  fi
  sleep 0.5
done

if [[ -f tmp/tunnel_url.txt ]]; then
  CALLBACK="$(cat tmp/tunnel_url.txt)"
  echo
  echo "Restarting Rails so it reloads .env CALLBACK_URL=$CALLBACK"
  kill "$DEV_PID" 2>/dev/null || true
  pkill -P "$DEV_PID" 2>/dev/null || true
  sleep 1
  # Clear trap target until new process
  DEV_PID=""
  bin/dev &
  DEV_PID=$!
  trap cleanup EXIT INT TERM
fi

wait "$TUNNEL_PID"
